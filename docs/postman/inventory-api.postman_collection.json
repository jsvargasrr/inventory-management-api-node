{
  "info": {
    "name": "MercadoExpress — Inventory API",
    "description": "Colección Postman para la prueba técnica de gestión de inventario",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "productId", "value": "" },
    { "key": "alertId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "List Products (paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=5",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "5" }
              ]
            }
          }
        },
        {
          "name": "List Products with Active Alert",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?hasActiveAlert=true",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [{ "key": "hasActiveAlert", "value": "true" }]
            }
          }
        },
        {
          "name": "Create Product",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('productId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Arroz Premium 1kg\",\n  \"sku\": \"GRA-001\",\n  \"category\": \"Granos\",\n  \"price\": 3500,\n  \"currentStock\": 100,\n  \"minStock\": 30,\n  \"supplier\": \"Granos del Norte\"\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Adjust Stock (Salida)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"SALIDA\",\n  \"quantity\": 10,\n  \"reason\": \"Venta mostrador\"\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}/adjustments"
          }
        },
        {
          "name": "List Movements",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}/movements"
          }
        }
      ]
    },
    {
      "name": "Alerts",
      "item": [
        {
          "name": "List Active Alerts",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const alerts = pm.response.json();",
                  "  if (alerts.length > 0) {",
                  "    pm.collectionVariables.set('alertId', alerts[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/alerts?status=ACTIVA",
              "host": ["{{baseUrl}}"],
              "path": ["alerts"],
              "query": [{ "key": "status", "value": "ACTIVA" }]
            }
          }
        }
      ]
    },
    {
      "name": "Purchase Orders",
      "item": [
        {
          "name": "Create Order from Alert",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('orderId', pm.response.json().id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"alertId\": \"{{alertId}}\",\n  \"quantity\": 50\n}"
            },
            "url": "{{baseUrl}}/purchase-orders"
          }
        },
        {
          "name": "List Orders (paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/purchase-orders?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["purchase-orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Approve Order",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/purchase-orders/{{orderId}}/approve"
          }
        },
        {
          "name": "Receive Order",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": "{{baseUrl}}/purchase-orders/{{orderId}}/receive"
          }
        },
        {
          "name": "Reject Order",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"reason\": \"Presupuesto no disponible este mes\"\n}"
            },
            "url": "{{baseUrl}}/purchase-orders/{{orderId}}/reject"
          }
        }
      ]
    }
  ]
}
